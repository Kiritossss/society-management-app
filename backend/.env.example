# Copy this file to .env and fill in real values. Never commit .env to git.

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/society_db

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Set to True during local development only
DEBUG=False

# Max API requests per minute per IP
RATE_LIMIT_PER_MINUTE=60
